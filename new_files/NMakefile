# Define the object files
CPP_OBJECTS = $(CPP_SOURCES:.cpp=.obj)
C_OBJECTS = $(C_SOURCES:.c=.obj)
OBJECTS = $(CPP_OBJECTS) $(C_OBJECTS)

!MESSAGE CPP_OBJECTS = $(CPP_OBJECTS)
!MESSAGE C_OBJECTS = $(C_OBJECTS)
!MESSAGE OBJECTS = $(OBJECTS)


# .exe is separate
MAIN_SRC = main.cpp
MAIN_OBJ = main.obj


# Define the compiler flags
CFLAGS = /O2 /EHsc /MD $(INCLUDES) /DM_PI=3.14159265358979323846 /Dssize_t=ptrdiff_t /std:c++17 -DWINDOWS -DNOMINMAX -DHAS_LGBM

# Define the linker flags
LDFLAGS = /LIBPATH:..\

# Define the libraries to link against
LIBS = ..\libfftw3-3.lib ..\libfftw3-3.lib ..\libfftw3l-3.lib ..\lib_lightgbm.lib

# default build
all: $(LIB_NAME) $(EXE_NAME)


# Build the static library
$(LIB_NAME): $(OBJECTS)
    lib /OUT:$(LIB_NAME) $(LDFLAGS) $(OBJECTS) $(LIBS) 

# Build the executable
$(EXE_NAME): $(MAIN_OBJ) $(OBJECTS) $(LIB_NAME)
	$(LINK) /OUT:$(EXE_NAME) $(MAIN_OBJ) $(OBJECTS) $(LIBS) $(LDFLAGS) /SUBSYSTEM:CONSOLE


# Compile the source files
#.cpp.obj:
#    $(CC) $(CFLAGS) /c $< /Fo$(@D)/
#.c.obj:
#    $(CC) $(CFLAGS) /c $< /Fo$(@D)/

# Compile the source files - revised 
.cpp.obj:
    $(CC) $(CFLAGS) /c $< /Fo$@
.c.obj:
    $(CC) $(CFLAGS) /c $< /Fo$@

# explicit rule for main.cpp
$(MAIN_OBJ): $(MAIN_SRC)
	$(CC) $(CFLAGS) /c $(MAIN_SRC) /Fo$(MAIN_OBJ)

# Clean up the build
clean:
	for /R %%f in (*.obj *.dll *.lib *.exe) do del "%%f"
